# Copy this file to .env to override defaults.
# SERVER_ID and AUTH_TOKEN are generated automatically on first run and
# written back to .env — you normally don't need to set them yourself.

# Server port — keep this on 3100 so it doesn't clash with the local ledger app (3001)
SERVER_PORT=3100

# Where the SQLite database file is stored
DATA_DIR=./data

# Auto-generated on first run if missing
SERVER_ID=
AUTH_TOKEN=

# Discord (optional)
DISCORD_WEBHOOK_URL=

# How long to keep uploaded sessions, in days
DATA_RETENTION_DAYS=90
